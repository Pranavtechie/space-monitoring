{
  "name": "space-monitoring",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@trpc/server": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "better-auth": "1.6.9",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.93.7"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter @space-monitoring/web dev",
    "db:push": "bun run --filter @app/db db:push",
    "db:generate": "bun run --filter @app/db db:generate",
    "deploy": "bun run --filter @app/infra deploy",
    "deploy:worker": "bun run deploy",
    "destroy": "bun run --filter @app/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@types/node": "catalog:",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "catalog:",
    "wrangler": "^4.91.0"
  },
  "packageManager": "bun@1.3.11"
}
